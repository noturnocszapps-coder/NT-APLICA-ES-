<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <rect width="1200" height="630" fill="#07090e" />
  
  <!-- Subtle Gradient Glows -->
  <circle cx="1000" cy="150" r="300" fill="#9333ea" opacity="0.15" filter="blur(60px)" />
  <circle cx="200" cy="500" r="250" fill="#3b82f6" opacity="0.12" filter="blur(60px)" />

  <!-- Grid Lines -->
  <path d="M0 100 H1200 M0 200 H1200 M0 300 H1200 M0 400 H1200 M0 500 H1200" stroke="#1f2937" stroke-width="1" opacity="0.3" />
  <path d="M200 0 V630 M400 0 V630 M600 0 V630 M800 0 V630 M1000 0 V630" stroke="#1f2937" stroke-width="1" opacity="0.3" />

  <!-- Logo Mark & Dot -->
  <g transform="translate(100, 120)">
    <circle cx="0" cy="0" r="8" fill="#a855f7" />
    <text x="24" y="6" font-family="Plus Jakarta Sans, sans-serif" font-weight="800" font-size="28" fill="#ffffff" letter-spacing="-0.5">NT Aplicações</text>
  </g>

  <!-- Tagline -->
  <text x="100" y="240" font-family="Plus Jakarta Sans, sans-serif" font-weight="800" font-size="52" fill="#ffffff" letter-spacing="-1">
    Tecnologia e Produtos Digitais
  </text>

  <text x="100" y="310" font-family="Plus Jakarta Sans, sans-serif" font-weight="400" font-size="24" fill="#9ca3af" width="800">
    Criamos e operamos produtos digitais próprios para demandas do mundo real.
  </text>

  <!-- Product Badges -->
  <g transform="translate(100, 420)">
    <!-- Roxou -->
    <rect x="0" y="0" width="140" height="42" rx="8" fill="#1e1b4b" stroke="#6366f1" stroke-width="1" />
    <text x="70" y="26" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#a5b4fc" text-anchor="middle">ROXOU</text>

    <!-- Partner Pro -->
    <rect x="160" y="0" width="170" height="42" rx="8" fill="#0f172a" stroke="#06b6d4" stroke-width="1" />
    <text x="245" y="26" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#67e8f9" text-anchor="middle">PARTNER PRO</text>

    <!-- Split Ready AI -->
    <rect x="350" y="0" width="180" height="42" rx="8" fill="#064e3b" stroke="#10b981" stroke-width="1" />
    <text x="440" y="26" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#6ee7b7" text-anchor="middle">SPLIT READY AI</text>

    <!-- Roxou Transporte -->
    <rect x="550" y="0" width="200" height="42" rx="8" fill="#451a03" stroke="#f59e0b" stroke-width="1" />
    <text x="650" y="26" font-family="JetBrains Mono, monospace" font-size="14" font-weight="700" fill="#fcd34d" text-anchor="middle">ROXOU TRANSPORTE</text>
  </g>

  <!-- Domain -->
  <text x="100" y="550" font-family="JetBrains Mono, monospace" font-size="16" fill="#6b7280">
    https://www.ntaplicacoes.com.br
  </text>
</svg>
